# Lab 28 - AI Platform Integration
# Copy this file to .env and fill in the values

# === Kaggle GPU Tunnel Configuration ===
# Choose ONE tunneling option (ngrok OR cloudflared)

# Option 1: ngrok (recommended)
VLLM_NGROK_URL=https://product-felt-tip-quizzical.ngrok-free.dev
EMBED_NGROK_URL=https://product-felt-tip-quizzical.ngrok-free.dev

# Option 2: cloudflared (alternative)
# VLLM_NGROK_URL=https://your-cloudflare-url.trycloudflare.com
# EMBED_NGROK_URL=https://your-embed-cloudflare-url.trycloudflare.com

# === LangSmith (Optional for observability) ===
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=lab28-platform

# === Service URLs (internal Docker network) ===
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# === Prefect Configuration ===
PREFECT_API_URL=http://prefect-orion:4200/api

# === Docker Compose Settings ===
COMPOSE_PROJECT_NAME=lab28
